---

interface Props {
  size?: 'header' | 'hero';
}


const { size } = Astro.props;

---
<svg class:list={['logo', `logo--${size}`]} viewBox="0 0 200 100" xmlns="http://www.w3.org/2000/svg">
    <path class="logo__v" d="M 15.135583,32.39821 41.604311,79.989758 40.474541,32.39821 h 10.135584 l 0.06987,62.288144 H 38.010518 L 5,32.39821 Z" aria-label="V"/>
    <path d="M59.67 94.894V6.207h14.443q10.135 0 14.95 5.828 4.814 5.702 4.814 18.118 0 15.457-10.769 19.004 6.462 1.52 9.502 6.461 3.168 4.942 3.168 13.937 0 12.923-4.815 19.13-4.814 6.209-14.823 6.209zM69.805 45.99h4.941q9.756 0 9.756-14.824v-3.04q0-7.222-2.407-10.516-2.281-3.42-7.349-3.42h-4.94zm0 40.922h6.082q5.194 0 7.601-3.547 2.407-3.675 2.407-11.403v-3.42q0-15.838-10.008-15.838h-6.082zm42.937-32.18v32.053h22.045v8.109h-32.18V6.207h31.8v8.109h-21.665v32.307h19.764v8.109zm61.814 21.158H163.28l-10.769-61.067v80.07h-9.882V6.208h15.457l10.769 61.447 10.896-61.447h15.457v88.687h-9.883V14.823Z" aria-label="BEM" fill="#999"/>
</svg>

<style lang="scss" is:global>
    .logo {
        --base-width: 200px;
        --base-height: 100px:
        --scale: 1;

        width: calc(var(--base-width) * var(--scale));
        height: calc(var(--base-height) * var(--scale));

        &--hero {
            --scale: 1.5;
        }

        &--header {
            --scale: .4;
        }

        &__v {
            fill: var(--color-logo-v);
        }
    }
</style>