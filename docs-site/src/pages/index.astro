---
import Layout from "@/layouts/Layout.astro";
import Logo from "@/components/Logo.astro";

---

<Layout title="vBEM" subtitle="Variance-Based Block Element Modifier" class="home-page">
	<div class="home-page__spotlight" />
	<section>
		<h2 class="home-page__title">
			<Logo size="hero" />
		</h2>
		<p class="home-page__subtitle">
			The design system architecture built for human velocity and agentic determinism. 
		</p>
		<p class="home-page__blurb">
			Turn CSS variables into strict visual contracts. vBEM eliminates DOM pollution, isolates component scope, and <strong>ends specificity wars forever.</strong>
			<br /><br />
			Ship deterministic UI that AI agents can reliably generate, and your team actually wants to read.
		</p>
		<div class="home-page__cta">
			<a href="/intro" class="button button--primary">
				View the Standard
			</a>
			<a
				href="https://github.com/f1yn/vBEM"
				class="button button--secondary"
				target="_blank"
			>
				GitHub
			</a>
		</div>
	</section>
</Layout>

<style lang="scss" is:global>
	.home-page {
		position: relative;
		display: flex;
		align-items: safe center;
		justify-content: center;
		padding: var(--spacing-5) 0;

		// We are using section as a literal semantic container here
		& > section {
			display: flex;
			flex-direction: column;
			width: calc(100% - var(--spacing-6));
			max-width: 800px;
			gap: var(--spacing-5);
		}

		&__subtitle {
			font-size: var(--font-size-7);
			color: var(--color-text-emphasis);
		}

		&__blurb {
			font-weight: 400;
			font-size: var(--font-size-4);
			color: var(--color-primary-darker);
			max-width: 600px;

			strong {
				font-weight: 600;
				color: var(--color-text-emphasis);
			}
		}

		&__cta {
			display: flex;
			gap: var(--spacing-4);
			align-items: flex-start;
		}

		&__spotlight {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			z-index: -1;
		}
	}
</style>