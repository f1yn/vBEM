---
import { getEntry, render } from "astro:content";

import Layout from "@/layouts/Layout.astro";
import DocContent from "@/components/DocContent.astro";
import { transformMarkdownLinks } from "@/common";

const readme = await getEntry('rootDocs', 'readme')!;
transformMarkdownLinks(readme.rendered!);
---

<Layout title="Introduction" subtitle="vBEM Overview">
	<DocContent>
		<Fragment set:html={readme.rendered?.html} />
	</DocContent>
</Layout>